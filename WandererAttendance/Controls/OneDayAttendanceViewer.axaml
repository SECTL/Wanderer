<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WandererAttendance.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WandererAttendance.Controls.OneDayAttendanceViewer"
             x:Name="RootControl">
    <ItemsControl DataContext="{Binding RelativeSource={RelativeSource AncestorType=local:OneDayAttendanceViewer}}"
                  ItemsSource="{Binding Data}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical" Spacing="8" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Expander Classes="stretch-header">
                    <Expander.Header>
                        <Grid ColumnDefinitions="* Auto" Margin="0 0 -12 0">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                <Run Text="{Binding Status.Name}" />
                                <Run Text="{Binding Count}" />
                                人
                            </TextBlock>
                            
                            <Button Grid.Column="1"
                                    Width="32" Height="32"
                                    Command="{Binding #RootControl.CopyStatusAndCountCommand}"
                                    CommandParameter="{Binding}"
                                    Theme="{StaticResource TransparentButton}"
                                    ToolTip.Tip="复制">
                                <local:FluentIcon Glyph="&#xE58B;" />
                            </Button>
                        </Grid>
                    </Expander.Header>
                                
                    <ItemsControl ItemsSource="{Binding Persons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemSpacing="4" LineSpacing="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                                    
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
