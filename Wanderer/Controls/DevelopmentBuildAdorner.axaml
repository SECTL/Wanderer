<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Wanderer.Controls"
                    xmlns:wanderer="clr-namespace:Wanderer">
    <ControlTemplate x:Key="DevelopmentBuildAdornerControlTemplate"
                     TargetType="controls:DevelopmentBuildAdorner">
        <Grid VerticalAlignment="Stretch"
              IsHitTestVisible="False"
              HorizontalAlignment="Stretch">
            <TextBlock VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       FontSize="12"
                       Opacity="0.8">
                开发中画面，不代表最终品质。<LineBreak/>
                Wanderer
                <Run Text="{x:Static wanderer:GlobalConstants.VersionLong}"/>
            </TextBlock>
        </Grid>
    </ControlTemplate>
    
    <ControlTheme TargetType="controls:DevelopmentBuildAdorner"
                  x:Key="{x:Type controls:DevelopmentBuildAdorner}">
        <Setter Property="Template" Value="{StaticResource DevelopmentBuildAdornerControlTemplate}"/>
    </ControlTheme>
</ResourceDictionary>
